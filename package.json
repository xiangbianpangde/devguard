{
  "name": "devguard",
  "version": "2.0.1",
  "private": true,
  "description": "通用开发规范 V2.0.1 模板（可复制到新项目）",
  "scripts": {
    "render": "python scripts/render_meta.py --render all",
    "render:check": "python scripts/render_meta.py --check",
    "test": "pytest tests/conventions/ -v",
    "compliance": "python scripts/check_compliance.py",
    "dashboard": "python docs/templates/devguard/html-report-template/render.py --meta conventions/_meta.yaml --status STATUS.md --out dashboard.html --l4-passed 53 --l4-total 53"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "markdownlint-cli": "^0.48.0"
  }
}
